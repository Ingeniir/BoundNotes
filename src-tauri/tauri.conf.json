{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Myapp",
  "version": "2.0.0",
  "identifier": "com.boundnotes.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BoundNotes",
        "width": 1280,
        "height": 800,
        "resizable": false,
        "decorations": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' blob: data: asset: http://asset.localhost https://asset.localhost tauri: ipc: http://ipc.localhost ws: wss: http: https:; img-src 'self' blob: data: asset: http://asset.localhost https://asset.localhost http: https:; connect-src 'self' ipc: http://ipc.localhost ws: wss:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}